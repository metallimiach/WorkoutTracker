# ==========================================
# 1. .NET / MAUI / Core Build Artifacts
# ==========================================
[Bb]in/
[Oo]bj/
artifacts/
TestResults/

# User-specific project settings
*.user
*.userosscache
*.sln.docstates
*.userprefs
*.ide/

# Debugging symbols & diagnostic logs
*.pdb
*.mdb
*.cache
*.log
*.tlog
*.lastcodeanalysissucceeded

# ==========================================
# 2. Package Management (NuGet)
# ==========================================
.nuget/
packages/
project.lock.json
project.fragment.lock.json
*.nupkg
*.snupkg

# ==========================================
# 3. IDEs & Editors (VS Code, Visual Studio, Rider)
# ==========================================
.vs/
.idea/
*.suo
*.sln.iml

# Only ignore VS Code workspace settings, NOT build/launch configurations
.vscode/
.vscode/*.log
.vscode/.history/

# ==========================================
# 4. macOS Operating System
# ==========================================
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes
*.icloud

# ==========================================
# 5. Apple/iOS Build Outputs (Keep Info.plist!)
# ==========================================
**/*.app
**/*.ipa
**/*.dSYM/
**/*.dSYM.zip
**/*.xcarchive/
*.maccatalyst/

# User-specific Xcode configuration
*.xcuserstate
*.xcuserdata/

# CRITICAL FIX: DO NOT ignore source .plist configuration files
!**/Info.plist
!**/Entitlements.plist

# CRITICAL FIX: Secure native keys, but keep provisioning profiles flexible
# Only ignore local certificate files if you drop them in your directory
*.p12
*.mobileprovision